<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  GoogleService-Info.plist.example

  Copy this file to GoogleService-Info.plist and fill in your own
  Firebase project credentials from the Firebase Console:
  https://console.firebase.google.com/

  Steps:
  1. Create a Firebase project (or use an existing one)
  2. Add an iOS app with your bundle ID
  3. Download GoogleService-Info.plist from Firebase Console
  4. Place it at PupillometryApp/GoogleService-Info.plist

  DO NOT commit the real GoogleService-Info.plist to version control.
-->
<plist version="1.0">
<dict>
	<key>API_KEY</key>
	<string>YOUR_FIREBASE_API_KEY</string>
	<key>GCM_SENDER_ID</key>
	<string>YOUR_GCM_SENDER_ID</string>
	<key>PLIST_VERSION</key>
	<string>1</string>
	<key>BUNDLE_ID</key>
	<string>YOUR_BUNDLE_ID</string>
	<key>PROJECT_ID</key>
	<string>YOUR_FIREBASE_PROJECT_ID</string>
	<key>STORAGE_BUCKET</key>
	<string>YOUR_PROJECT_ID.firebasestorage.app</string>
	<key>IS_ADS_ENABLED</key>
	<false/>
	<key>IS_ANALYTICS_ENABLED</key>
	<false/>
	<key>IS_APPINVITE_ENABLED</key>
	<true/>
	<key>IS_GCM_ENABLED</key>
	<true/>
	<key>IS_SIGNIN_ENABLED</key>
	<true/>
	<key>GOOGLE_APP_ID</key>
	<string>YOUR_GOOGLE_APP_ID</string>
</dict>
</plist>
